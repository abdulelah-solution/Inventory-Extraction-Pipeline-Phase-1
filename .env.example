# --- إعدادات قاعدة البيانات (SQL Server) ---
# ملاحظة: إذا كنت تستخدم WSL، اترك DB_SERVER فارغاً ليقوم الكود بجلبه تلقائياً
DB_SERVER=your_server_ip_or_hostname
DB_NAME=your_database_name
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# --- إعدادات المجلدات واللوج ---
OUTPUT_DIR=./output
LOG_LEVEL=INFO